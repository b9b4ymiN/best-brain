{
  "name": "best-brain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local AI work operating system with a persona brain, mission manager, and local worker runtime.",
  "scripts": {
    "dev": "bun src/mcp/index.ts",
    "server": "bun src/server.ts",
    "manager": "bun scripts/manager.ts",
    "test": "bun test tests/config.test.ts tests/brain.test.ts tests/bootstrap.test.ts tests/contracts.test.ts tests/eval.test.ts tests/examples.test.ts tests/http.test.ts tests/mcp.test.ts tests/manager.test.ts tests/manager-http.test.ts tests/onboarding.test.ts tests/seed.test.ts",
    "typecheck": "tsc --noEmit",
    "seed:persona": "bun scripts/seed-persona.ts",
    "validate:seeds": "bun scripts/validate-seeds.ts",
    "onboard": "bun scripts/onboard.ts",
    "eval:consult": "bun scripts/run-consult-eval.ts",
    "eval:consult:bless": "bun scripts/bless-consult-baseline.ts",
    "eval:seed": "bun scripts/run-seed-comparison.ts",
    "examples:manager": "bun scripts/generate-manager-examples.ts",
    "smoke:bootstrap": "bun scripts/run-bootstrap-smoke.ts",
    "smoke:bootstrap:proof": "bun scripts/capture-bootstrap-proof.ts",
    "smoke:mcp": "bun scripts/run-mcp-smoke.ts",
    "smoke:claude": "bun scripts/run-claude-mcp-smoke.ts",
    "smoke:manager": "bun scripts/run-manager-thin-smoke.ts",
    "smoke:manager:claude": "bun scripts/run-manager-claude-smoke.ts",
    "smoke:manager:codex": "bun scripts/run-manager-codex-smoke.ts",
    "oracle-core:test": "bun test --cwd brain/oracle-core src/integration/database.test.ts",
    "oracle-core:server": "bun run --cwd brain/oracle-core server"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "hono": "^4.11.3"
  },
  "devDependencies": {
    "bun-types": "^1.3.6",
    "typescript": "^5.7.2"
  }
}
